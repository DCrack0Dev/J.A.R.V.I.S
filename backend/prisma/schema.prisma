generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

model JobListing {
  id           String           @id @default(uuid()) @db.Uuid
  externalId   String?          @map("external_id")
  title        String
  company      String
  location     String?
  isRemote     Boolean          @default(false) @map("is_remote")
  description  String?
  url          String
  source       String
  stackTags    String[]         @map("stack_tags")
  salaryRange  String?          @map("salary_range")
  postedAt     DateTime?        @map("posted_at")
  scrapedAt    DateTime         @default(now()) @map("scraped_at")
  isArchived   Boolean          @default(false) @map("is_archived")
  applications JobApplication[]

  @@unique([externalId, source])
  @@map("job_listings")
}

model JobApplication {
  id                String      @id @default(uuid()) @db.Uuid
  listingId         String?     @map("listing_id") @db.Uuid
  status            String      @default("pending_review")
  coverLetter       String?     @map("cover_letter")
  cvSnapshot        Json?       @map("cv_snapshot")
  appliedAt         DateTime?   @map("applied_at")
  lastStatusChange  DateTime    @default(now()) @map("last_status_change")
  notes             String?
  emailThreadId     String?     @map("email_thread_id")
  createdAt         DateTime    @default(now()) @map("created_at")
  listing           JobListing? @relation(fields: [listingId], references: [id])

  @@map("job_applications")
}

model UserProfile {
  id           String   @id @default(uuid()) @db.Uuid
  fullName     String?  @map("full_name")
  email        String?
  phone        String?
  location     String?
  linkedinUrl  String?  @map("linkedin_url")
  githubUrl    String?  @map("github_url")
  portfolioUrl String?  @map("portfolio_url")
  summary      String?
  skills       String[]
  targetRoles  String[] @map("target_roles")
  experience   Json?
  education    Json?
  updatedAt    DateTime @default(now()) @map("updated_at")

  @@map("user_profile")
}

model GithubRepo {
  id            String    @id @default(uuid()) @db.Uuid
  repoId        BigInt    @unique @map("repo_id")
  name          String
  fullName      String    @map("full_name")
  description   String?
  url           String?
  isPrivate     Boolean   @default(false) @map("is_private")
  language      String?
  stars         Int       @default(0)
  forks         Int       @default(0)
  openIssues    Int       @default(0) @map("open_issues")
  topics        String[]
  readmeContent String?   @map("readme_content")
  readmeSha     String?   @map("readme_sha")
  lastPushedAt  DateTime? @map("last_pushed_at")
  lastSyncedAt  DateTime  @default(now()) @map("last_synced_at")
  aiHealthScore Int?      @map("ai_health_score")
  aiSuggestions Json?     @map("ai_suggestions")

  @@map("github_repos")
}

model GithubProfile {
  id                 String   @id @default(uuid()) @db.Uuid
  username           String   @unique
  displayName        String?  @map("display_name")
  bio                String?
  avatarUrl          String?  @map("avatar_url")
  followers          Int?
  following          Int?
  publicRepos        Int?     @map("public_repos")
  profileReadme      String?  @map("profile_readme")
  profileReadmeSha   String?  @map("profile_readme_sha")
  totalStars         Int?     @map("total_stars")
  topLanguages       Json?    @map("top_languages")
  contributionStreak Int?     @map("contribution_streak")
  lastSyncedAt       DateTime @default(now()) @map("last_synced_at")

  @@map("github_profile")
}

model GithubEdit {
  id              String   @id @default(uuid()) @db.Uuid
  repoFullName    String?  @map("repo_full_name")
  editType        String   @map("edit_type")
  originalContent String?  @map("original_content")
  newContent      String?  @map("new_content")
  aiPromptUsed    String?  @map("ai_prompt_used")
  committedAt     DateTime? @map("committed_at")
  commitSha       String?  @map("commit_sha")
  status          String   @default("pending")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("github_edits")
}

model ScheduleDay {
  id        String          @id @default(uuid()) @db.Uuid
  day       String          @unique // mon, tue, wed, thu, fri, sat, sun
  theme     String
  blocks    ScheduleBlock[]
  updatedAt DateTime        @default(now()) @map("updated_at")

  @@map("schedule_days")
}

model ScheduleBlock {
  id          String      @id @default(uuid()) @db.Uuid
  dayId       String      @map("day_id") @db.Uuid
  start       String      // "05:30"
  end         String      // "06:00"
  icon        String
  label       String
  detail      String
  order       Int         @default(0)
  day         ScheduleDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@map("schedule_blocks")
}

model ConversationSession {
  id         String            @id @default(uuid()) @db.Uuid
  userId     String?           @db.Uuid
  summary    String?
  topicTags  String[]          @map("topic_tags")
  createdAt  DateTime          @default(now()) @map("created_at")
  snapshots  ContextSnapshot[]

  @@map("conversation_sessions")
}

model ContextSnapshot {
  id           String              @id @default(uuid()) @db.Uuid
  sessionId    String              @map("session_id") @db.Uuid
  messageIndex Int                 @map("message_index")
  intentLabel  String?             @map("intent_label")
  sentiment    String?
  entities     Json?
  timestamp    DateTime            @default(now())
  session      ConversationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("context_snapshots")
}

model UserMemory {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String?  @unique @db.Uuid
  preferredTone      String?  @map("preferred_tone")
  responseLength     String?  @map("response_length")
  topicWeights       Json?    @map("topic_weights")
  personalityProfile Json?    @map("personality_profile")
  lastUpdated        DateTime @default(now()) @map("last_updated")

  @@map("user_memories")
}

// --- NEW MODULE 1: PERMANENT MEMORY ENGINE ---

model MemoryRecord {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  role      String   // user or assistant
  content   String
  sessionId String   @map("session_id")
  timestamp DateTime @default(now())

  @@map("memory_records")
}

model MemoryIndex {
  id              String                    @id @default(uuid()) @db.Uuid
  userId          String?                   @db.Uuid
  summary         String
  tags            String[]
  embedding       Unsupported("vector(1536)")?
  sourceSessionId String?                   @map("source_session_id")
  createdAt       DateTime                  @default(now()) @map("created_at")

  @@map("memory_index")
}

model MemoryCorrection {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String?  @db.Uuid
  originalFact  String   @map("original_fact")
  correctedFact String   @map("corrected_fact")
  timestamp     DateTime @default(now())

  @@map("memory_corrections")
}

// --- NEW MODULE 2: ADAPTIVE LEARNING ---

model ExplanationFeedback {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String?  @db.Uuid
  messageId    String?  @map("message_id")
  rating       String?  // positive, negative
  feedbackType String?  @map("feedback_type") // too_long, too_short, need_examples, etc.
  timestamp    DateTime @default(now())

  @@map("explanation_feedback")
}

model DiagramCache {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @db.Uuid
  description String
  mermaidCode String   @map("mermaid_code")
  renderedAt  DateTime @default(now()) @map("rendered_at")

  @@map("diagram_cache")
}

// --- NEW MODULE 3: REAL-TIME INTELLIGENCE ---

model TrackedAsset {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String?  @db.Uuid
  symbol         String   // e.g., BTC, ETH
  alertThreshold Float?   @map("alert_threshold") // percentage move, e.g. 5.0
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("tracked_assets")
}

model IntelligenceAlert {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @db.Uuid
  provider    String   // crypto, cyber, trading, news
  message     String
  severity    String   // low, medium, high, critical
  triggeredAt DateTime @default(now()) @map("triggered_at")
  acknowledged Boolean  @default(false)

  @@map("intelligence_alerts")
}

model NewsCache {
  id        String   @id @default(uuid()) @db.Uuid
  topic     String
  headline  String
  url       String
  source    String
  fetchedAt DateTime @default(now()) @map("fetched_at")

  @@map("news_cache")
}

// --- NEW MODULE 4: WAKE WORD & SESSION PERSISTENCE ---

enum SessionStatus {
  DORMANT
  ACTIVE
}

model JarvisSession {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String?       @db.Uuid
  status        SessionStatus @default(DORMANT)
  lastActiveAt  DateTime?     @map("last_active_at")
  lastSleptAt   DateTime?     @map("last_slept_at")
  totalSessions Int           @default(0) @map("total_sessions")
  createdAt     DateTime      @default(now()) @map("created_at")

  @@map("jarvis_sessions")
}

model UserAudioSettings {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @unique @db.Uuid
  wakeWordEnabled  Boolean  @default(false) @map("wake_word_enabled")
  panicMuteActive  Boolean  @default(false) @map("panic_mute_active")
  consentGivenAt   DateTime? @map("consent_given_at")
  updatedAt        DateTime @default(now()) @map("updated_at")

  @@map("user_audio_settings")
}

model ToolCall {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String?  @db.Uuid
  messageId      String?  @map("message_id")
  toolName       String   @map("tool_name")
  cacheHit       Boolean  @map("cache_hit")
  responseTimeMs Int      @map("response_time_ms")
  status         String   @default("SUCCESS") // SUCCESS, FAILED
  timestamp      DateTime @default(now())

  @@map("tool_calls")
}

